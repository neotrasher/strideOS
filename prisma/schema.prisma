generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ConnectionProvider {
  STRAVA
  GARMIN_FILE
}

enum ActivitySource {
  STRAVA
  GARMIN
  MANUAL
}

enum ActivitySport {
  RUN
  TRAIL_RUN
  TREADMILL
  OTHER
}

enum SyncStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum GoalType {
  WEEKLY_KM
  WEEKLY_LOAD
  TENK_TIME
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

model User {
  id          String             @id @default(cuid())
  email       String             @unique
  name        String?
  timezone    String             @default("America/Bogota")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  connections Connection[]
  activities  Activity[]
  plans       TrainingPlan[]
  syncRuns    SyncRun[]
  aiReports   ActivityAIReport[]
  goals       Goal[]
}

model Connection {
  id                String             @id @default(cuid())
  userId            String
  provider          ConnectionProvider
  externalAthleteId String?
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, provider])
}

model Activity {
  id                   String               @id @default(cuid())
  userId               String
  source               ActivitySource
  externalId           String
  sport                ActivitySport        @default(RUN)
  name                 String
  startedAt            DateTime
  distanceM            Float?
  movingTimeS          Int?
  elapsedTimeS         Int?
  elevationGainM       Float?
  averageHr            Int?
  maxHr                Int?
  averageCadence       Float?
  averagePower         Float?
  averagePaceSecondsKm Float?
  rpe                  Int?
  summary              String?
  rawPayload           Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiReports            ActivityAIReport[]
  planMatches          ActivityPlanMatch[]

  @@unique([source, externalId])
  @@index([userId, startedAt])
}

model TrainingPlan {
  id        String           @id @default(cuid())
  userId    String
  name      String
  goal      String?
  startsOn  DateTime?
  endsOn    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions  PlannedSession[]
}

model PlannedSession {
  id                  String               @id @default(cuid())
  trainingPlanId      String
  title               String
  scheduledFor        DateTime
  objective           String?
  targetDistanceM     Float?
  targetPaceSecondsKm Float?
  targetDurationS     Int?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  trainingPlan        TrainingPlan         @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)
  activityMatches     ActivityPlanMatch[]

  @@index([trainingPlanId, scheduledFor])
}

model ActivityPlanMatch {
  id               String         @id @default(cuid())
  activityId       String
  plannedSessionId String
  score            Float
  notes            String?
  createdAt        DateTime       @default(now())
  activity         Activity       @relation(fields: [activityId], references: [id], onDelete: Cascade)
  plannedSession   PlannedSession @relation(fields: [plannedSessionId], references: [id], onDelete: Cascade)

  @@unique([activityId, plannedSessionId])
}

model ActivityAIReport {
  id                     String   @id @default(cuid())
  userId                 String
  activityId             String
  model                  String?
  adherenceScore         Float?
  summaryShort           String
  summaryCoach           String?
  recoveryRecommendation String?
  keyDeviations          Json?
  riskFlags              Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  activity               Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([activityId])
}

model SyncRun {
  id            String             @id @default(cuid())
  userId        String
  provider      ConnectionProvider
  status        SyncStatus         @default(PENDING)
  startedAt     DateTime?
  finishedAt    DateTime?
  cursor        String?
  importedCount Int                @default(0)
  error         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, provider, createdAt])
}

model Goal {
  id        String   @id @default(cuid())
  userId    String
  title     String
  type      GoalType
  status    GoalStatus @default(ACTIVE)
  target    Float
  raceName  String?
  raceDistanceKm Float?
  dueDate   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dueDate])
}
